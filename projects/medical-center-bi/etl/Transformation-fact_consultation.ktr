    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// 1. Gestion de l'indicateur binaire de retard (Tâche 3.5)
// Si le Calculator renvoie un retard strictement supérieur à 0, l'indicateur passe à 1, sinon 0.
var indicateur_consultation_en_retard = (retard_en_minutes > 0) ? 1 : 0;

// 2. Règle métier sur le montant net (Tâche 3.6)
var montant_net = 0;

// Si la consultation est annulée, le montant net est forcé à 0.
// Sinon, on récupère le montant calculé par le Calculator.
if (statut_consultation.toString() === "Annulée") {
    montant_net = 0;
} else {
    montant_net = montant_net_calcul;
}

// 3. Compteur d'agrégation unitaire pour les calculs de volumes (Tâche 3.4)
var nombre_consultations = 1;

</jsScript_script>
      </jsScript>
    </jsScripts>
