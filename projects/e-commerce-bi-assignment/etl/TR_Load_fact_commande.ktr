        <jsScript_script>// 1. Initialisation par défaut des indicateurs de retard
var retard_jours = 0;
var indicateur_livraison_en_retard = 0;

// 2. Calcul uniquement si le retard brut calculé par le Calculator existe (non null)
if (retard_jours_brut != null) {
    retard_jours = (retard_jours_brut &lt; 0) ? 0 : retard_jours_brut;
    indicateur_livraison_en_retard = (retard_jours_brut > 0) ? 1 : 0;
}

// 3. Génération de la clé temporelle au format Integer (yyyyMMdd)
var formatDate = new java.text.SimpleDateFormat("yyyyMMdd");
var chaineDate = formatDate.format(date_commande);
var temps_pk = java.lang.Integer.parseInt(chaineDate);</jsScript_script>
